# Local development — copy this to .env.local and fill in values
# After AWS deployment, values come from CloudFormation outputs

REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_WS_URL=ws://localhost:8086
REACT_APP_TURN_URL=turn:localhost:3478

# Cognito — from CloudFormation outputs
REACT_APP_COGNITO_POOL_ID=us-east-1_XXXXXXXXX
REACT_APP_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_COGNITO_REGION=us-east-1

# S3 — from CloudFormation output S3BucketName
REACT_APP_S3_BUCKET=hiresphere-submissions-local

# Stripe publishable key (safe to expose in frontend)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_placeholder
